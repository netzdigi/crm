# Clerk (https://dashboard.clerk.com) — required for the /login page to work.
# Get these from your Clerk instance's "API Keys" page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon Postgres — required for every company page (/[company]/...) and /admin.
# Add the Neon integration via the Vercel Marketplace; it usually sets this for you.
DATABASE_URL=postgres://...
