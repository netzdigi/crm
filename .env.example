# Clerk (https://dashboard.clerk.com) — required for the /login page to work.
# Get these from your Clerk instance's "API Keys" page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon Postgres — required for the /clients page and the Shopify sync.
# Added automatically when you connect a Neon database via the Vercel
# Marketplace (Vercel project -> Storage -> Create Database -> Neon).
DATABASE_URL=postgresql://...

# Shopify app — required for the Shopify sync. Shopify discontinued
# static-token legacy custom apps on 2026-01-01, so new apps (Settings ->
# Apps and sales channels -> Develop apps -> Build apps) use OAuth instead.
# SHOPIFY_API_KEY and SHOPIFY_API_SECRET come from the app's "Client
# credentials"/"API credentials" section. SHOPIFY_ADMIN_ACCESS_TOKEN is NOT
# shown in the UI anymore — get it by visiting /api/shopify/install once
# (after setting the other three vars and deploying), which walks through
# the OAuth flow and displays the token once for you to copy here.
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=shpss_...
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...

# Used once by `npm run shopify:register-webhooks`, not needed at runtime.
# (Or, since this sandbox can't reach Shopify directly, visit
# /api/shopify/register-webhooks?secret=<SHOPIFY_API_SECRET> once deployed.)
SHOPIFY_WEBHOOK_URL=https://your-domain.vercel.app/api/webhooks/shopify
