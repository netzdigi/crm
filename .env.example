# Clerk (https://dashboard.clerk.com) — required for the /login page to work.
# Get these from your Clerk instance's "API Keys" page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon Postgres — required for the /clients page and the Shopify sync.
# Added automatically when you connect a Neon database via the Vercel
# Marketplace (Vercel project -> Storage -> Create Database -> Neon).
DATABASE_URL=postgresql://...

# Shopify Custom App — required for the Shopify webhook sync.
# Create the app in your Shopify admin: Settings -> Apps and sales channels
# -> Develop apps -> Create an app. Enable the read_customers and
# read_orders Admin API scopes, install the app, then copy the values
# below from its "API credentials" tab.
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
SHOPIFY_API_SECRET=shpss_...

# Used once by `npm run shopify:register-webhooks`, not needed at runtime.
SHOPIFY_WEBHOOK_URL=https://your-domain.vercel.app/api/webhooks/shopify
